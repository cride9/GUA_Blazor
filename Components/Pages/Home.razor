@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>GUA - Companion</PageTitle>

<div class="chat-root">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="logo-mark"><img class="logo-img" src="/imgs/logo.png" asp-append-version="true" /></span>
            <span class="logo-text">GUA</span>
        </div>

        <button class="new-chat-btn" @onclick="StartNewChat">
            <span class="btn-icon">+</span>
            New chat
        </button>

        <div class="history-label">Recent</div>
        <ul class="history-list">
            @foreach (var session in chatHistory)
            {
                <li class="history-item @(session.Key == activeSessionId ? "active" : "")"
                    @onclick="() => LoadSession(session.Key)">
                    <span class="history-icon">💬</span>
                    <span class="history-title">@session.Value.Title</span>
                </li>
            }
        </ul>
    </aside>

    <main class="chat-main">
        <header class="chat-header">
            <span class="model-badge">GUA Companion</span>
        </header>

        <div class="messages-area" id="messagesArea">
            @if (chatHistory.ContainsKey(activeSessionId))
            {
                @if (!activeSession.Messages.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">✦</div>
                        <h2 class="empty-title">How can I help you?</h2>
                        <p class="empty-sub">Ask me anything. I'm here to assist.</p>
                    </div>
                }
                var messageIndex = 0;
                
                @foreach (var msg in activeSession.Messages)
                {
                    var hasToolcall = !msg.IsUser && HasToolcall(msg.Content);
                    var cleanContent = hasToolcall ? StripToolcall(msg.Content) : msg.Content;

                    <div class="message @(msg.IsUser ? "user-msg" : "ai-msg")">
                        @if (!msg.IsUser)
                        {
                            <div class="avatar ai-avatar">G</div>
                        }
                        @if (msg.IsUser)
                        {
                            <div class="avatar user-avatar">U</div>
                        }
        
                        <div class="message-content-wrapper">
                            <div class="bubble @(msg.IsUser ? "user-bubble" : "ai-bubble") markdown-body">
                                @((MarkupString)RenderMarkdown(cleanContent))
                            </div>

                            @if (hasToolcall)
                            {
                                var capturedIndex = messageIndex;
                                <div class="toolcall-container">
                                    <button class="toolcall-toggle" @onclick="() => ToggleToolcall(capturedIndex)">
                                        <svg class="toolcall-gear-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="3" />
                                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06
                                            a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09
                                            A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83
                                            l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09
                                            A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83
                                            l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09
                                            a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83
                                            l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09
                                            a1.65 1.65 0 0 0-1.51 1z" />
                                        </svg>
                                        <span class="toolcall-label">Toolcall</span>
                                        <svg class="toolcall-arrow @(expandedToolcalls.Contains(capturedIndex) ? "expanded" : "")"
                                             xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                             fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="6 9 12 15 18 9" />
                                        </svg>
                                    </button>
                    
                                    @if (expandedToolcalls.Contains(capturedIndex))
                                    {
                                        <div class="toolcall-dropdown">
                                            <div class="toolcall-header">
                                                <span>Tool Execution Details</span>
                                                <button class="toolcall-copy" @onclick="() => CopyToClipboard(ExtractToolcallJson(msg.Content))">
                                                    📋 Copy
                                                </button>
                                            </div>
                                            <pre class="toolcall-json"><code>@ExtractToolcallJson(msg.Content)</code></pre>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
    
                    messageIndex++;
                }
            }

            @if (isLoading)
            {
                <div class="message ai-msg">
                    <div class="avatar ai-avatar">G</div>
                    <div class="bubble typing-bubble">
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                    </div>
                </div>
            }
        </div>

        <div class="input-area">
            <div class="input-wrapper">
                <textarea class="chat-input"
                          placeholder="Message GUA…"
                          @bind="inputText"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          rows="1"
                          disabled="@isLoading"></textarea>
                <button class="send-btn @(CanSend ? "active" : "")"
                        @onclick="SendMessage"
                        disabled="@(!CanSend)"
                        title="Send message">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="19" x2="12" y2="5" />
                        <polyline points="5 12 12 5 19 12" />
                    </svg>
                </button>
            </div>
            <p class="input-hint">GUA can make mistakes. Double-check important info.</p>
        </div>
    </main>
</div>