@page "/"
@using GUA_Blazor.Models
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment

<PageTitle>GUA - Companion</PageTitle>

<div class="chat-root">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="logo-mark"><img class="logo-img" src="/imgs/logo.png" asp-append-version="true" /></span>
            <span class="logo-text">GUA</span>
        </div>

        <button class="new-chat-btn" @onclick="StartNewChat">
            <span class="btn-icon">+</span>
            New chat
        </button>

        <div class="history-label">Recent</div>
        <ul class="history-list">
            @foreach (var session in chatHistory)
            {
                <li class="history-item @(session.Key == activeSessionId ? "active" : "")"
                    @onclick="() => LoadSession(session.Key)">
                    <span class="history-icon">💬</span>
                    <span class="history-title">@session.Value.Title</span>
                </li>
            }
        </ul>
    </aside>

    <main class="chat-main">
        <header class="chat-header">
            <span class="model-badge">GUA Companion</span>
    
            <div class="mode-toggle-wrapper">
                <span class="mode-label @(!isAgentMode ? "active" : "")">Chat</span>
        
                <button class="mode-toggle @(isAgentMode ? "agent" : "")"
                        @onclick="() => isAgentMode = !isAgentMode"
                        title="@(isAgentMode ? "Switch to Chat" : "Switch to Agent")">
                    <div class="mode-toggle-thumb">
                        @if (isAgentMode)
                        {
                            <!-- Agent icon: cpu/chip -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="6" height="6" />
                                <path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3" />
                                <rect x="4" y="4" width="16" height="16" rx="2" />
                            </svg>
                        }
                        else
                        {
                            <!-- Chat icon: message bubble -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                            </svg>
                        }
                    </div>
                </button>
        
                <span class="mode-label @(isAgentMode ? "active" : "")">Agent</span>
            </div>
        </header>

        <div class="messages-area" id="messagesArea">

            @if (!chatHistory.ContainsKey(activeSessionId) || !activeSession.Messages.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">✦</div>
                    <h2 class="empty-title">How can I help you?</h2>
                    <p class="empty-sub">Ask me anything. I'm here to assist.</p>
                </div>
            }
            @if (chatHistory.ContainsKey(activeSessionId))
            {
                var messageIndex = 0;
                var groups = GroupMessages();

                @foreach (var (msg, toolFollowers) in groups)
                {
                    var allToolcallMessages = new List<ChatMessage>();
                    if (HasToolcall(msg.Content)) allToolcallMessages.Add(msg);
                    allToolcallMessages.AddRange(toolFollowers);

                    var cleanContent = StripToolcall(msg.Content);

                    <div class="message @(msg.IsUser ? "user-msg" : "ai-msg")" @key="msg">
                        @if (!msg.IsUser)
                        {
                            <div class="avatar ai-avatar">G</div>
                        }
                        @if (msg.IsUser)
                        {
                            <div class="avatar user-avatar">U</div>
                        }

                        <div class="message-content-wrapper">
                            @if (!string.IsNullOrWhiteSpace(cleanContent))
                            {
                                <div class="bubble @(msg.IsUser ? "user-bubble" : "ai-bubble") markdown-body">
                                    @((MarkupString)RenderMarkdown(cleanContent))
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(msg.VoiceMessagePath))
                            {
                                <div class="voice-message-container">
                                    <button class="voice-play-btn" type="button">
                                        <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                                    </button>

                                    <div class="voice-waveform paused">
                                        <div class="voice-wave-bar"></div>
                                        <div class="voice-wave-bar"></div>
                                        <div class="voice-wave-bar"></div>
                                        <div class="voice-wave-bar"></div>
                                        <div class="voice-wave-bar"></div>
                                        <div class="voice-wave-bar"></div>
                                    </div>

                                    <span class="voice-time">0:00 / 0:00</span>

                                    <div class="voice-progress-container">
                                        <div class="voice-progress-bar" style="width: 0%"></div>
                                    </div>

                                    <button class="voice-volume-btn" type="button">
                                        <svg viewBox="0 0 24 24">
                                            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                                            <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                                        </svg>
                                    </button>

                                    <button class="voice-more-btn" type="button">
                                        <svg viewBox="0 0 24 24">
                                            <circle cx="12" cy="5" r="2"></circle>
                                            <circle cx="12" cy="12" r="2"></circle>
                                            <circle cx="12" cy="19" r="2"></circle>
                                        </svg>
                                    </button>

                                    <audio src="@GetAudioDataUrl(msg.VoiceMessagePath)" preload="metadata" crossorigin="anonymous"></audio>
                                </div>
                            }

                            @if (msg.AttachmentPaths.Any())
                            {
                                <div class="attachment-row">
                                    @foreach (var path in msg.AttachmentPaths)
                                    {
                                        var ext = Path.GetExtension(path).ToLowerInvariant();
                                        var isImage = ext is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp";

                                        @if (isImage)
                                        {
                                            <div class="attachment-thumb-wrapper">
                                                <img class="attachment-thumb"
                                                     src="@GetImageDataUrl(path)"
                                                     alt="attachment"
                                                     @onclick="() => OpenImagePreview(path)" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="attachment-file-chip">
                                                <span class="attachment-file-icon">@GetFileIcon(ext)</span>
                                                <span class="attachment-file-name">@Path.GetFileName(path)</span>
                                            </div>
                                        }
                                    }
                                </div>
                            }

                            @if (allToolcallMessages.Any())
                            {
                                <div class="toolcall-row">
                                    @foreach (var tcMsg in allToolcallMessages)
                                    {
                                        var capturedIndex = messageIndex++;
                                        <div class="toolcall-container">
                                            <button class="toolcall-toggle" @onclick="() => ToggleToolcall(capturedIndex)">
                                                <svg class="toolcall-gear-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="12" cy="12" r="3" />
                                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06
                                                    a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09
                                                    A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83
                                                    l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09
                                                    A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83
                                                    l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09
                                                    a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83
                                                    l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09
                                                    a1.65 1.65 0 0 0-1.51 1z" />
                                                </svg>
                                                <span class="toolcall-label">Tool Execution</span>
                                                <svg class="toolcall-arrow @(expandedToolcalls.Contains(capturedIndex) ? "expanded" : "")"
                                                     xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="6 9 12 15 18 9" />
                                                </svg>
                                            </button>

                                            @if (expandedToolcalls.Contains(capturedIndex))
                                            {
                                                <div class="toolcall-dropdown">
                                                    <div class="toolcall-header">
                                                        <span>Tool Execution Details</span>
                                                        <button class="toolcall-copy" @onclick="() => CopyToClipboard(ExtractToolcallJson(tcMsg.Content))">
                                                            📋 Copy
                                                        </button>
                                                    </div>
                                                    <pre class="toolcall-json"><code>@ExtractToolcallJson(tcMsg.Content)</code></pre>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (!allToolcallMessages.Any())
                            {
                                messageIndex++;
                            }
                        </div>
                    </div>
                }

                @if (previewImageUrl is not null)
                {
                    <div class="image-preview-overlay" @onclick="ClosePreview">
                        <img class="image-preview-full" src="@previewImageUrl" alt="preview" />
                    </div>
                }
            }

            @if (isLoading)
            {
                <div class="message ai-msg">
                    <div class="avatar ai-avatar">G</div>
                    <div class="bubble typing-bubble">
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                    </div>
                </div>
            }
        </div>

        <div class="input-area">

            @if (uploadedFiles.Any())
            {
                <div class="file-preview-row">
                    @foreach (var file in uploadedFiles)
                    {
                        <div class="file-chip">
                            <svg class="file-chip-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14 2 14 8 20 8" />
                            </svg>
                            <span class="file-chip-name">@file.Name</span>
                            <span class="file-chip-size">@FormatFileSize(file.Size)</span>
                            <button class="file-chip-remove" @onclick="() => RemoveFile(file)" title="Remove">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18" />
                                    <line x1="6" y1="6" x2="18" y2="18" />
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            }

            <div class="input-wrapper">
                <label class="upload-btn" title="Attach files">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66
                        l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" />
                    </svg>
                    <InputFile class="input-upload" OnChange="LoadFiles" multiple
                               accept="image/*,video/*,audio/*,.pdf,.txt,.md,.csv,.json,.xml,.yaml,.yml,.cs,.py,.js,.ts,.html,.css,.sql" />
                </label>

                <textarea class="chat-input"
                          placeholder="Message GUA…"
                          @ref="textareaRef"
                          @bind="inputText"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          rows="1"
                          disabled="@isLoading"></textarea>

                <button class="send-btn @(CanSend ? "active" : "")"
                        @onclick="SendMessage"
                        disabled="@(!CanSend)"
                        title="Send message">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="19" x2="12" y2="5" />
                        <polyline points="5 12 12 5 19 12" />
                    </svg>
                </button>
            </div>

            <p class="input-hint">GUA can make mistakes. Double-check important info.</p>
        </div>
    </main>
</div>
